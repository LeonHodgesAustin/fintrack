# ============================================================
# fintrack -- environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ============================================================

# ---- Plaid (required) --------------------------------------
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_secret_here
PLAID_ENV=sandbox          # sandbox | production

# ---- Database ----------------------------------------------
DB_PATH=fintrack.db

# ---- Plaid Link appearance ---------------------------------
PLAID_CLIENT_NAME=MyFintrackExtreme
LINK_SERVER_PORT=5000
# Plaid products to request. "transactions" covers depository + credit accounts.
# Add "investments" only if you need brokerage holdings/trade data AND have
# implemented the investment sync endpoints (/investments/holdings/get etc.).
PLAID_PRODUCTS=transactions
FLASK_SECRET_KEY=change-me-before-any-real-use
LINK_CUSTOMIZATION_NAME=default

# ---- Token encryption (recommended) -----------------------
# Generate with: fintrack keygen
# WARNING: losing this key means re-linking all institutions.
# Leave blank to store tokens as plaintext (not recommended).
FERNET_KEY=

# ---- Google Sheets ----------------------------------------
# Share your spreadsheet with the service account email (Editor access).
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
GOOGLE_SPREADSHEET_ID=

# ---- ntfy.sh push notifications ---------------------------
# Pick any unique topic name and subscribe in the ntfy phone app.
# No account needed. Leave blank to disable push notifications.
NTFY_TOPIC=my_fintrack_alert_extreme
NTFY_SERVER=https://ntfy.sh

# ---- Alert thresholds -------------------------------------
LARGE_TRANSACTION_THRESHOLD=500.0   # alert on single transactions above this amount
LARGE_TRANSACTION_LOOKBACK_DAYS=1   # how far back to look for large transactions
SPENDING_SPIKE_PCT=50.0             # alert if a category is up >N% MoM
FORECAST_ANOMALY_SIGMA=2.0          # Prophet: flag months > N sigma above forecast

# ---- Recurring expense detection --------------------------
RECURRING_LOOKBACK_DAYS=180         # history window for auto-detection
RECURRING_MIN_OCCURRENCES=2         # minimum appearances to be considered recurring
RECURRING_WINDOW_DAYS=5             # day-of-month tolerance (+/- days)
RECURRING_AMOUNT_TOLERANCE=0.20     # max fractional amount variance (0.20 = 20%)
RECURRING_UPCOMING_DAYS=7           # alert for charges due within N days
RECURRING_MISSING_GRACE_DAYS=5      # charge overdue after N days past expected date

# Manual recurring expenses (auto-detected entries are merged with these).
# Format: "Merchant Name|monthly_amount|day_of_month"
# Example: RECURRING_EXPENSES=Netflix|15.99|15,Spotify|9.99|20,Rent|2500|1
RECURRING_EXPENSES=

# Merchants to EXCLUDE from auto-detection (comma-separated, case-insensitive).
# Use this to suppress false positives like payroll appearing as a "recurring charge".
# Example: RECURRING_EXCLUDE_MERCHANTS=Employer Name,Zelle From Dad
RECURRING_EXCLUDE_MERCHANTS=

# ---- Cashflow ---------------------------------------------
# Categories excluded from income/expense totals (treated as internal transfers).
CASHFLOW_TRANSFER_CATEGORIES=TRANSFER_IN,TRANSFER_OUT

# ---- Classifier chain -------------------------------------
# Ordered, comma-separated classifier names. Each is tried in order;
# the first non-None result wins. Available: rules, plaid, llm (drop-in slot).
CLASSIFIER_CHAIN=rules,plaid

# ---- Rentcast property valuation (optional) ---------------
# Used by `fintrack assets property refresh` to fetch Zestimate-style AVM values.
# Free tier: ~50 requests/month. Sign up at https://www.rentcast.io
# Leave blank to set property values manually.
RENTCAST_API_KEY=

# ---- LLM classifier (optional) ----------------------------
# Only needed if you add fintrack/classification/llm.py.
# Set CLASSIFIER_CHAIN=llm,rules,plaid to enable.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8
