# ── Plaid credentials ─────────────────────────────────────────────────────────
# Get these from https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_sandbox_secret_here

# sandbox | production
# Always start with sandbox; never flip to production until smoke tests pass.
PLAID_ENV=sandbox

# ── Storage ───────────────────────────────────────────────────────────────────
# Absolute or relative path to the SQLite database file.
DB_PATH=fintrack.db

# ── Classification chain ──────────────────────────────────────────────────────
# Comma-separated list of classifier names tried in order.
# Each classifier returns None if it can't handle the transaction; the next is tried.
# Built-in names: rules, plaid
# Add "llm" here once you implement fintrack/classification/llm.py
CLASSIFIER_CHAIN=rules,plaid

# ── Link server ───────────────────────────────────────────────────────────────
LINK_SERVER_PORT=5000
# Flask secret key — any random string, used only for session signing
FLASK_SECRET_KEY=change-me-in-production

# ── LLM classifier (optional) ─────────────────────────────────────────────────
# Uncomment when you add fintrack/classification/llm.py
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-opus-4-8
